# =====================================================
# Velocewealth — Environment variables
# Copy this file to .env.local and fill in real values.
# =====================================================

# ----- Public app -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase (Phase 3a) -----
# Get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- Mapbox (Phase 3b) -----
# Get a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ----- Google Cloud Vision OCR (Phase 3b) -----
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Vision API
# 3. Create a service account, download JSON key
# 4. Paste the entire JSON content as a single line below
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ----- Stripe (Phase 3c) -----
# Get these from https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get this from https://dashboard.stripe.com → Developers → Webhooks (after creating an endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a product + recurring price in Stripe, paste the price IDs here
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ----- Sentry (Phase 5, optional) -----
# Get a DSN at https://sentry.io → your project → Settings → Client Keys
# If empty, Sentry stays disabled (build still works).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ----- RLS audit (Phase 5, optional) -----
# Two test users used by tests/audit/rls-audit.mjs
SUPABASE_TEST_USER_A_EMAIL=
SUPABASE_TEST_USER_A_PASSWORD=
SUPABASE_TEST_USER_B_EMAIL=
SUPABASE_TEST_USER_B_PASSWORD=
